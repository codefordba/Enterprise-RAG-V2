# ==============================================================================
# ENTERPRISE-RAG-V2 DOCKERIZED ENVIRONMENT PROFILE
# ==============================================================================

# ------------------------------------------------------------------------------
# CHOOSE YOUR DEPLOYMENT SCENARIO & CONFIGURE ENDPOINTS ACCORDINGLY
# ------------------------------------------------------------------------------

# --- SCENARIO A: Services run directly on your HOST Machine (Localhost outside Docker)
# Since the app container has 'host.docker.internal' mapped, use it to reach your host services:
# QDRANT_HOST=host.docker.internal
# QDRANT_PORT=6333
# EMBEDDING_SERVER_URL=http://host.docker.internal:8090
# RERANKER_SERVER_URL=http://host.docker.internal:8081

# --- SCENARIO B: Services run inside a Docker bridge network (e.g. docker-compose.infra.yml)
# Use container names to resolve endpoint locations:
#QDRANT_HOST=rag-qdrant
#QDRANT_PORT=6333
#EMBEDDING_SERVER_URL=http://10.145.244.17:8080
#RERANKER_SERVER_URL=http://10.145.244.17:80

# --- SCENARIO C: Services run on a Remote Server or Cloud instance
# Use the direct IP address or hostname of the remote servers:
 QDRANT_HOST=10.145.244.17
 QDRANT_PORT=6333
 EMBEDDING_SERVER_URL=http://10.145.244.17:8090
 RERANKER_SERVER_URL=http://10.145.244.17:8081


# ------------------------------------------------------------------------------
# GENERIC SETTINGS (Do not modify unless required)
# ------------------------------------------------------------------------------
COLLECTION_NAME=tenant_knowledge_base
RERANK_ENABLED=True

# --- CROSS-PLATFORM CPU/GPU FALLBACK OPTIONS (For local docker-compose.infra.yml) ---
# Image tags to use when starting local infrastructure services:
EMBEDDING_IMAGE_TAG=cpu-latest
RERANKER_IMAGE_TAG=cpu-latest
EMBEDDING_NUM_THREADS=8

# Volume paths for local infrastructure persistence:
QDRANT_STORAGE_PATH=./qdrant_storage
EMBEDDING_CACHE_PATH=./embedding_cache
RERANKER_CACHE_PATH=./reranker_cache

# --- CORE LLM SETTINGS (vLLM / Cloud inference base config) ---
LLM_DEPLOYMENT_MODE=ON_PREM
LLM_API_BASE_URL=http://10.145.244.17:8000/v1
LLM_API_KEY=none
DEFAULT_MODEL_ID=gemini-1.5-pro
